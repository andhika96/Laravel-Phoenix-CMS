{
	"name": "laravel/laravel",
	"type": "project",
	"description": "The skeleton application for the Laravel framework.",
	"keywords": ["laravel", "framework"],
	"license": "MIT",
	"require": {
		"php": "^8.3",
		"brokenice/laravel-mysql-partition": "^2.0",
		"climactic/laravel-credits": "^1.3",
		"dedoc/scramble": "^0.13.22",
		"diglactic/laravel-breadcrumbs": "^10.1.0",
		"gasparesganga/php-shapefile": "^3.4",
		"geoip2/geoip2": "3.2.0",
		"hisorange/browser-detect": "^5.0",
		"intervention/image": "^3.11",
		"josiasmontag/laravel-recaptchav3": "^1.0",
		"laravel/framework": "^13.0",
		"laravel/octane": "^2.13",
		"laravel/passport": "^13.7",
		"laravel/reverb": "^1.0",
		"laravel/socialite": "^5.14",
		"laravel/tinker": "^3.0",
		"league/flysystem-aws-s3-v3": "^3.0",
		"php-coord/php-coord": "^5.10",
		"proj4php/proj4php": "^2.0",
		"socialiteproviders/microsoft-azure": "^5.2",
		"spatie/laravel-permission": "^6.7",
		"tomloprod/memoize": "^1.0",
		"torann/geoip": "*"
	},
	"require-dev": {
		"fakerphp/faker": "^1.23",
		"kitloong/laravel-migrations-generator": "^7.2",
		"laravel/pint": "^1.13",
		"laravel/sail": "^1.26",
		"mockery/mockery": "^1.6",
		"nunomaduro/collision": "^8.6",
		"phpunit/phpunit": "^12.5.12",
		"spatie/laravel-ignition": "^2.4"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app/",
			"Database\\Factories\\": "database/factories/",
			"Database\\Seeders\\": "database/seeders/"
		},
		"files" : [
			"app\\Helper\\Common.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"scripts": {
		"post-autoload-dump": [
			"Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
			"@php artisan package:discover --ansi"
		],
		"post-update-cmd": [
			"@php artisan vendor:publish --tag=laravel-assets --ansi --force"
		],
		"post-root-package-install": [
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
		],
		"post-create-project-cmd": [
			"@php artisan key:generate --ansi",
			"@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
			"@php artisan migrate --graceful --ansi"
		]
	},
	"extra": {
		"laravel": {
			"dont-discover": [
				"brokenice/laravel-mysql-partition"
			]
		}
	},
	"config": {
		"optimize-autoloader": true,
		"preferred-install": "dist",
		"sort-packages": true,
		"allow-plugins": {
			"pestphp/pest-plugin": true,
			"php-http/discovery": true
		}
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
