			function undo() {
				if (histIdx.value <= 0) return;
				traveling.value = true; histIdx.value--;
				rootNodes.value = norm(JSON.parse(hist.value[histIdx.value]));
				selectedId.value = '';
				nextTick(() => traveling.value = false);
			}
			function redo() {
				if (histIdx.value >= hist.value.length - 1) return;
				traveling.value = true; histIdx.value++;
				rootNodes.value = norm(JSON.parse(hist.value[histIdx.value]));
				selectedId.value = '';
				nextTick(() => traveling.value = false);
