			// ── Find ─────────────────────────────────────────────────────────
			function findById(nodes, id) {
				for (const n of nodes) {
					if (n.id === id) return n;
					if (n.children) { const r = findById(n.children, id); if (r) return r; }
					if (n.columns) for (const col of n.columns) { const r = findById(col.children||[], id); if (r) return r; }
