.pb-collapsible[open] summary::before {
	content: '\25BE';
}

.pb-collapsible-body {
	padding: 10px 0 4px;
}

.pb-toggle-label-row {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 10px;
}

.pb-toggle-switch-wrap {
	display: inline-flex;
	align-items: center;
	gap: 8px;
}

.pb-toggle-state {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	min-width: 24px;
	height: 20px;
	border-radius: 999px;
	padding: 0 8px;
	background: #373e4c;
	color: #b7c0d4;
	font-size: 11px;
	font-weight: 700;
	text-transform: lowercase;
}

.pb-input-with-action {
	display: grid;
	grid-template-columns: 1fr 34px;
}

.pb-input-with-action .pb-input {
	border-top-right-radius: 0;
	border-bottom-right-radius: 0;
}

.pb-field-action-btn {
	border: 1px solid #3a4254;
