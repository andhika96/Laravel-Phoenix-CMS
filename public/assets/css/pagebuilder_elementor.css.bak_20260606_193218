/* =============================================
   THEME-AWARE SIDEBAR TITLES (Light / Dark)
   Menjaga judul kategori tetap terbaca di kedua mode.
   ============================================= */
[data-bs-theme="light"] .pb-panel.left .pb-collapsible {
	border-bottom-color: #e6ebf4 !important;
}

[data-bs-theme="light"] .pb-panel.left .pb-collapsible summary {
	color: #243047 !important;
}

[data-bs-theme="light"] .pb-panel.left .pb-collapsible summary::before,
[data-bs-theme="light"] .pb-panel.left .pb-prop-section-title::before {
	color: #8795ad !important;
}

[data-bs-theme="light"] .pb-panel.left .pb-prop-section-title {
	color: #243047 !important;
}

[data-bs-theme="dark"] .pb-panel.left .pb-collapsible {
	border-bottom-color: #2a303c !important;
}

[data-bs-theme="dark"] .pb-panel.left .pb-collapsible summary {
	color: #f5f8ff !important;
}

[data-bs-theme="dark"] .pb-panel.left .pb-collapsible summary::before,
[data-bs-theme="dark"] .pb-panel.left .pb-prop-section-title::before {
	color: #a8b0c2 !important;
}

[data-bs-theme="dark"] .pb-panel.left .pb-prop-section-title {
	color: #f7f9ff !important;
}

/* =============================================
   RESPONSIVE CONTROL ALIGNMENT (Elementor-like)
   Menempatkan icon device di samping label opsi.
   ============================================= */
.pb-label-row.pb-label-row-device {
	justify-content: flex-start;
	gap: 6px;
	position: relative;
	overflow: visible;
}

.pb-label-row.pb-label-row-device > .pb-form-label {
	margin-bottom: 0;
}

.pb-label-row.pb-label-row-device > .pb-control-device-wrap {
	margin-left: 4px;
}

.pb-label-row.pb-label-row-device > .pb-label-tools {
	display: flex;
	align-items: center;
	gap: 8px;
	flex: 1 1 auto;
	min-width: 0;
	margin-left: 4px;
}

.pb-label-row.pb-label-row-device > .pb-label-tools .pb-control-unit-wrap {
	margin-left: auto;
	padding-left: 6px;
}

.pb-control-device-menu {
	min-width: 152px;
	max-width: min(220px, calc(100vw - 44px));
	white-space: nowrap;
}
