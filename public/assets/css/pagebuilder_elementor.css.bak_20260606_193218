	color: #d4dbee;
	height: 32px;
}

.pb-field-action-btn:hover {
	background: #2a3140;
	color: #ffffff;
}

.pb-advanced-switch-grid {
	margin-top: 8px;
	display: grid;
	gap: 8px;
}

